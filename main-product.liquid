<section class="product">
  <div class="product__media">
    {% if product.featured_image %}
      <img class="product__media-main" id="ProductMainImage"
           src="{{ product.featured_image | image_url: width: 1400 }}"
           alt="{{ product.featured_image.alt | escape | default: product.title }}">
    {% else %}
      <img class="product__media-main" id="ProductMainImage"
           src="{{ 'bottle-solo.png' | asset_url }}" alt="{{ product.title | escape }}">
    {% endif %}

    {% if product.images.size > 1 %}
      <div class="product__thumbs">
        {% for image in product.images limit: 4 %}
          <img class="product__thumb" src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | escape }}"
               onclick="document.getElementById('ProductMainImage').src='{{ image | image_url: width: 1400 }}'">
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="product__info">
    <div class="eyebrow product__eyebrow">{{ section.settings.eyebrow }}</div>
    <h1 class="product__title">{{ product.title }}</h1>

    <div class="product__price">
      {% if product.compare_at_price > product.price %}
        {{ product.price | money }} <span class="meta" style="text-decoration:line-through;opacity:.6;">{{ product.compare_at_price | money }}</span>
      {% else %}
        {{ product.price | money }}
      {% endif %}
    </div>

    {% if product.metafields.custom.tasting_notes != blank %}
      {% assign chips = product.metafields.custom.tasting_notes | split: ',' %}
      <div class="chips" style="justify-content:flex-start;">
        {% for chip in chips %}<span class="chip">{{ chip | strip }}</span>{% endfor %}
      </div>
    {% else %}
      <div class="chips" style="justify-content:flex-start;">
        <span class="chip">Yuzu</span><span class="chip">Citrus blossom</span><span class="chip">Fine bubbles</span>
      </div>
    {% endif %}

    <div class="product__desc rte">
      {% if product.description != blank %}{{ product.description }}{% else %}<p>A vivid magenta sparkling spritz — bright real yuzu over fine, weightless bubbles. Citrus blossom, a coastal lift, a clean dry finish.</p>{% endif %}
    </div>

    {% form 'product', product, class: 'product__form' %}
      {% unless product.has_only_default_variant %}
        <select name="id" class="product__variant">
          {% for variant in product.variants %}
            <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
              {{ variant.title }} — {{ variant.price | money }}{% unless variant.available %} (Sold out){% endunless %}
            </option>
          {% endfor %}
        </select>
      {% else %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      {% endunless %}

      {% if product.available %}
        <button type="submit" name="add" class="btn btn--plum btn--block">{{ section.settings.button_label }} — {{ product.price | money }}</button>
      {% else %}
        <button type="button" class="btn btn--block" disabled>Sold out</button>
      {% endif %}

      <span class="product__meta">{{ section.settings.meta }}</span>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WIMO · Sparkling Yuzu" },
    { "type": "text", "id": "button_label", "label": "Add to cart label", "default": "Add to cart" },
    { "type": "text", "id": "meta", "label": "Meta line", "default": "750ml · 11% ABV · Free shipping over $120" }
  ]
}
{% endschema %}
