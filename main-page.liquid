<div class="page-hero">
  <div class="eyebrow page-hero__eyebrow">{{ section.settings.eyebrow | default: 'WIMO' }}</div>
  <h1 class="page-hero__title">{{ page.title }}</h1>
</div>

<div class="page-body">
  <div class="rte">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WIMO" }
  ]
}
{% endschema %}
