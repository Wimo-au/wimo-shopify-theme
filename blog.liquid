<div class="collection-head">
  <div class="eyebrow page-hero__eyebrow">WIMO · Journal</div>
  <h1 class="page-hero__title">{{ blog.title }}</h1>
</div>

<div class="collection-grid">
  {% for article in blog.articles %}
    <a class="pcard" href="{{ article.url }}">
      <div class="pcard__img" style="background-image:url('{% if article.image %}{{ article.image | image_url: width: 700 }}{% else %}{{ 'glass-coast.png' | asset_url }}{% endif %}');"></div>
      <div class="pcard__title">{{ article.title }}</div>
      <div class="pcard__price">{{ article.published_at | date: '%B %-d, %Y' }}</div>
    </a>
  {% else %}
    <p class="lede" style="grid-column:1/-1;text-align:center;">No posts yet.</p>
  {% endfor %}
</div>
