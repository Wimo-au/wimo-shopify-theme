<div class="page-hero" style="padding-top:120px;">
  <div class="eyebrow page-hero__eyebrow">WIMO · your wine moment</div>
  <h1 class="page-hero__title">Opening soon</h1>
</div>
<div class="page-body" style="text-align:center;">
  <p class="lede" style="margin:0 auto 36px;">{{ shop.password_message | default: 'A vivid new wine moment is on its way.' }}</p>
  {% form 'storefront_password' %}
    <div class="search-form" style="margin:0 auto;">
      <input type="password" name="password" placeholder="Enter store password">
      <button type="submit" class="btn btn--plum">Enter</button>
    </div>
  {% endform %}
</div>
