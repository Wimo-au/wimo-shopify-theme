{%- assign img = section.settings.image -%}
{%- assign page_mode = section.settings.page_mode -%}
{%- if template contains 'partner' %}{% assign page_mode = true %}{% endif -%}
<section class="partner {% if page_mode %}partner--page{% endif %}" data-snap data-label="{{ section.settings.dot_label }}">
  <div class="partner__text" data-reveal>
    <div class="partner__eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="partner__title">{{ section.settings.title_line1 }}<br><strong>{{ section.settings.title_line2 }}</strong></h2>
    <p class="partner__lede">{{ section.settings.text }}</p>

    <div class="partner__grid">
      {% for block in section.blocks %}
        <div class="partner__card" {{ block.shopify_attributes }}>
          <div class="ic">{{ block.settings.icon }}</div>
          <div class="h">{{ block.settings.heading }}</div>
          <div class="p">{{ block.settings.text }}</div>
        </div>
      {% endfor %}
    </div>

    {% form 'contact', class: 'partner__form' %}
      {% if form.posted_successfully? %}
        <p style="color:#7A2E55;font-size:16px;">Thank you — our trade team will be in touch within two business days.</p>
      {% endif %}
      <input type="hidden" name="contact[tags]" value="trade-enquiry">
      <input type="text" name="contact[Venue]" placeholder="Venue / business name" required>
      <input type="text" name="contact[name]" placeholder="Your name" required>
      <input type="email" name="contact[email]" placeholder="Email" required>
      <select name="contact[Partner type]">
        <option>Bar / Restaurant</option><option>Bottle shop</option><option>Events / Venue</option><option>Other</option>
      </select>
      <div class="partner__actions">
        <button type="submit" class="partner__btn">{{ section.settings.button_label }}</button>
        <a class="partner__email" href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
      </div>
    {% endform %}
  </div>

  {% unless page_mode %}
    <div class="partner__img" data-reveal style="background-image:url('{% if img %}{{ img | image_url: width: 1600 }}{% else %}{{ 'bottle-cheers.png' | asset_url }}{% endif %}');">
      <div class="partner__img-scrim"></div>
    </div>
  {% endunless %}
</section>

{% schema %}
{
  "name": "Partner with us",
  "settings": [
    { "type": "checkbox", "id": "page_mode", "label": "Full-width page layout (use on a page)", "default": false },
    { "type": "image_picker", "id": "image", "label": "Image (homepage layout)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Partner with us" },
    { "type": "text", "id": "title_line1", "label": "Title line 1", "default": "Pour WIMO at" },
    { "type": "text", "id": "title_line2", "label": "Title line 2 (bold)", "default": "your venue" },
    { "type": "textarea", "id": "text", "label": "Intro", "default": "We work hand in hand with bars, restaurants and bottle shops across Australia. If you'd love to see Purple Flame on your list or your shelves, let's talk." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send enquiry" },
    { "type": "text", "id": "email", "label": "Trade email", "default": "trade@wimo.wine" },
    { "type": "text", "id": "dot_label", "label": "Page-dot label", "default": "Partner" }
  ],
  "blocks": [
    {
      "type": "type",
      "name": "Partner type",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (glyph)", "default": "◍" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Bars & Restaurants" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "A vivid spritz and cocktail base your guests remember." }
      ]
    }
  ],
  "max_blocks": 3,
  "default": {
    "blocks": [
      { "type": "type", "settings": { "icon": "◍", "heading": "Bars & Restaurants", "text": "A vivid spritz and cocktail base your guests remember." } },
      { "type": "type", "settings": { "icon": "⬡", "heading": "Bottle Shops", "text": "A standout small-batch addition to your fridge." } },
      { "type": "type", "settings": { "icon": "✦", "heading": "Events & Venues", "text": "Bright, easy pours for weddings and functions." } }
    ]
  },
  "presets": [{ "name": "Partner with us" }]
}
{% endschema %}
